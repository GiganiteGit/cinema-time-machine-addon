# TMDB credentials — supply ONE of the two (read token preferred).
# Get them free at https://www.themoviedb.org/settings/api
# Real values go in .env.local (gitignored) — keep this file placeholders only.

# v4 read access token (a long JWT). Sent as: Authorization: Bearer <token>
TMDB_READ_TOKEN=

# v3 API key (32 hex chars). Sent as: ?api_key=<key>
TMDB_API_KEY=

# Supabase durable cache (Phase 4) — shared FindMyLegacy project, ANON key.
# Also backs the privacy-preserving usage analytics (ctm_events table).
SUPABASE_URL=
SUPABASE_KEY=

# Usage analytics salt. A stable secret that turns client IPs into unrecoverable
# pseudonyms for distinct-user counts — any long random string. Set a real one in
# the deploy env; analytics no-ops entirely if SUPABASE_URL/KEY are unset.
ANALYTICS_SALT=
